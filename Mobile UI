    note: "Heat pump failed to produce heat, cooling worked",
  },
];

type Status = "not_touched" | "in_progress" | "complete";

function statusDot(status: Status) {
  if (status === "complete") return <CheckCircle2 className="h-5 w-5" />;
  if (status === "in_progress") return <Clock3 className="h-5 w-5" />;
  return <Circle className="h-5 w-5" />;
}

function statusTone(status: Status) {
  if (status === "complete") return "bg-green-50 border-green-200";
  if (status === "in_progress") return "bg-yellow-50 border-yellow-200";
  return "bg-slate-50 border-slate-200";
}

export default function HomeScopeMobileScaffold() {
  const [activeSection, setActiveSection] = useState("Plumbing");
  const [sections, setSections] = useState(checklistData);
  const [recentObservations, setRecentObservations] = useState(seedObservations);
  const [showPanels, setShowPanels] = useState(true);

  const currentSection = useMemo(
    () => sections.find((section) => section.section === activeSection) ?? sections[0],
    [sections, activeSection]
  );

  function sectionCounts(items: { status: Status }[]) {
    const complete = items.filter((i) => i.status === "complete").length;
    const progress = items.filter((i) => i.status === "in_progress").length;
    return { complete, progress, total: items.length };
  }

  function cycleStatus(sectionName: string, itemId: string) {
    setSections((prev) =>
      prev.map((section) => {
        if (section.section !== sectionName) return section;
        return {
          ...section,
          items: section.items.map((item) => {
            if (item.id !== itemId) return item;
            const nextStatus: Status =
              item.status === "not_touched"
                ? "in_progress"
                : item.status === "in_progress"
                ? "complete"
                : "not_touched";
            return { ...item, status: nextStatus };
          }),
        };
      })
    );
  }

  function captureObservation() {
    const firstOpenItem = currentSection.items.find((item) => item.status !== "complete") ?? currentSection.items[0];

    if (firstOpenItem) {
      setSections((prev) =>
        prev.map((section) => {
          if (section.section !== currentSection.section) return section;
          return {
            ...section,
            items: section.items.map((item) =>
              item.id === firstOpenItem.id && item.status === "not_touched"
                ? { ...item, status: "in_progress" as Status }
                : item
            ),
          };
        })
      );
    }

    setRecentObservations((prev) => [
      {
        id: `obs_${String(prev.length + 1).padStart(3, "0")}`,
        time: "Now",
        section: currentSection.section,
        item: firstOpenItem?.label ?? "General",
        note: `New observation captured in ${currentSection.section}`,
      },
      ...prev,
    ]);
  }

  return (
    <div className="min-h-screen bg-slate-100 p-4 md:p-8">
      <div className="mx-auto grid max-w-7xl gap-6 lg:grid-cols-[320px_1fr]">
        <Card className="rounded-3xl border-0 shadow-sm">
          <CardHeader>
            <div className="flex items-center justify-between gap-3">
              <div>
                <p className="text-sm text-slate-500">Inspection</p>
                <CardTitle className="text-2xl">3839 Orchard Way</CardTitle>
              </div>
              <Badge variant="secondary" className="rounded-full">In Progress</Badge>
            </div>
          </CardHeader>
          <CardContent className="space-y-4">
            <Button className="w-full rounded-2xl py-6 text-base" onClick={captureObservation}>
              <Camera className="mr-2 h-5 w-5" />
              Capture Observation
            </Button>

            <Button
              variant="outline"
              className="w-full rounded-2xl py-5 text-base"
              onClick={() => setShowPanels((prev) => !prev)}
            >
              <Layout className="mr-2 h-5 w-5" />
              {showPanels ? "Hide Detail Panels" : "Show Detail Panels"}
            </Button>

            <div className="space-y-2 max-h-[65vh] overflow-y-auto pr-1">
              {sections.map((section) => {
                const counts = sectionCounts(section.items as { status: Status }[]);
                const isActive = activeSection === section.section;
                return (
                  <button
                    key={section.section}
                    onClick={() => setActiveSection(section.section)}
                    className={`w-full rounded-2xl border p-3 text-left transition ${
                      isActive ? "border-slate-900 bg-white shadow-sm" : "border-slate-200 bg-white/70"
                    }`}
                  >
                    <div className="flex items-center justify-between gap-3">
                      <div>
                        <p className="font-medium text-slate-900">{section.section}</p>
                        <p className="text-sm text-slate-500">
                          {counts.complete}/{counts.total} complete
                          {counts.progress > 0 ? ` · ${counts.progress} in progress` : ""}
                        </p>
                      </div>
                      <ChevronRight className="h-4 w-4 text-slate-400" />
                    </div>
                  </button>
                );
              })}
            </div>
          </CardContent>
        </Card>

        {showPanels && (
          <div className="grid gap-6">
            <Card className="rounded-3xl border-0 shadow-sm">
              <CardHeader>
                <div className="flex items-center justify-between gap-4">
                  <div>
                    <p className="text-sm text-slate-500">Section detail</p>
                    <CardTitle className="text-2xl">{currentSection.section}</CardTitle>
                  </div>
                  <Badge className="rounded-full">All subsections visible</Badge>
                </div>
              </CardHeader>
              <CardContent className="grid gap-3 md:grid-cols-2">
                {currentSection.items.map((item) => (
                  <button
                    key={item.id}
                    onClick={() => cycleStatus(currentSection.section, item.id)}
                    className={`rounded-2xl border p-4 text-left transition ${statusTone(item.status as Status)}`}
                  >
                    <div className="flex items-start justify-between gap-3">
                      <div>
                        <p className="font-medium text-slate-900">{item.label}</p>
                        <p className="mt-1 text-sm text-slate-600">
                          {item.status === "complete"
                            ? "Checked and accounted for"
                            : item.status === "in_progress"
                            ? "Observation captured"
                            : "Not checked yet"}
                        </p>
                      </div>
                      <div className="text-slate-700">{statusDot(item.status as Status)}</div>
                    </div>
                  </button>
                ))}
              </CardContent>
            </Card>

            <Card className="rounded-3xl border-0 shadow-sm">
              <CardHeader>
                <div className="flex items-center justify-between gap-4">
                  <div>
                    <p className="text-sm text-slate-500">Recent captures</p>
                    <CardTitle className="text-2xl">Observation queue</CardTitle>
                  </div>
                  <Badge variant="secondary" className="rounded-full">Desktop review later</Badge>
                </div>
              </CardHeader>
              <CardContent className="space-y-3">
                {recentObservations.map((obs) => (
                  <div key={obs.id} className="rounded-2xl border border-slate-200 bg-white p-4">
                    <div className="mb-2 flex items-center justify-between gap-3">
                      <div>
                        <p className="font-medium text-slate-900">{obs.note}</p>
                        <p className="text-sm text-slate-500">{obs.section} · {obs.item}</p>
                      </div>
                      <Badge variant="outline" className="rounded-full">{obs.time}</Badge>
                    </div>
                    <p className="text-sm text-slate-600">Photo and voice note saved for desktop review.</p>
                  </div>
                ))}
              </CardContent>
            </Card>
          </div>
        )}
      </div>
    </div>
  );
}

